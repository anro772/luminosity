<UserControl x:Class="Luminosity.AppRulesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="13" Foreground="{StaticResource TextBrush}">

    <!-- Dim backdrop fills the whole window; the card is centred and scrolls internally. -->
    <Border Background="#CC090B0F">
        <Border Style="{StaticResource Card}" Width="660" Margin="40"
                HorizontalAlignment="Center" VerticalAlignment="Stretch" Padding="0">
            <Grid Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <StackPanel HorizontalAlignment="Left">
                        <TextBlock Text="App rules" FontSize="19" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Auto-apply colors while a game/app runs; revert when it closes."
                                   Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,2,0,0" />
                    </StackPanel>
                    <Button Content="✕" Style="{StaticResource IconButton}" HorizontalAlignment="Right"
                            VerticalAlignment="Top" Click="Close_Click" ToolTip="Close" />
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Existing rules -->
                        <TextBlock Text="YOUR RULES" Foreground="{StaticResource MutedBrush}" FontSize="11"
                                   FontWeight="SemiBold" Margin="0,0,0,8" />
                        <StackPanel x:Name="RulesPanel" />
                        <TextBlock x:Name="NoRulesText" Text="No rules yet — create one below."
                                   Foreground="{StaticResource MutedBrush}" FontStyle="Italic" />

                        <Separator Background="{StaticResource CardBorderBrush}" Margin="0,16" />

                        <!-- New / edit rule -->
                        <TextBlock x:Name="SectionTitle" Text="NEW RULE" Foreground="{StaticResource MutedBrush}"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />

                        <Grid Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="ChooseAppButton" Content="Choose running app…"
                                        Style="{StaticResource GhostButton}" Click="ChooseApp_Click" />
                                <TextBlock x:Name="PickedLabel" VerticalAlignment="Center" Margin="12,0,0,0"
                                           Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                            </StackPanel>
                            <CheckBox x:Name="ShowAllToggle" Content="Show all processes" HorizontalAlignment="Right"
                                      VerticalAlignment="Center" Checked="ShowAll_Changed" Unchecked="ShowAll_Changed" />
                        </Grid>

                        <Border x:Name="ProcessListHost" Visibility="Collapsed" Style="{StaticResource Card}"
                                Padding="6" Margin="0,0,0,12">
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ProcessList" />
                            </ScrollViewer>
                        </Border>

                        <StackPanel x:Name="EditorSection" Visibility="Collapsed">
                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock Text="Rule name" VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}" Margin="0,0,10,0" />
                                    <TextBox x:Name="RuleNameBox" Width="240" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Tick the controls this rule should change, then set their target values."
                                       Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,10" />
                            <WrapPanel x:Name="MonitorEditorHost" Orientation="Horizontal" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Grid Grid.Row="2" Margin="0,14,0,0">
                    <Button x:Name="SaveButton" Content="Save rule" Style="{StaticResource AccentButton}"
                            HorizontalAlignment="Left" IsEnabled="False" Click="SaveRule_Click" />
                    <Button x:Name="CancelEditButton" Content="Cancel edit" Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Left" Margin="120,0,0,0" Visibility="Collapsed" Click="CancelEdit_Click" />
                    <Button Content="Close" Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Right" Click="Close_Click" />
                </Grid>
            </Grid>
        </Border>
    </Border>
</UserControl>
