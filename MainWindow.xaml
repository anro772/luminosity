<Window x:Class="Luminosity.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Luminosity"
        Title="Luminosity" Height="840" Width="980"
        MinHeight="560" MinWidth="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI" FontSize="13" Foreground="{StaticResource TextBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Luminosity" FontSize="22" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock x:Name="SubtitleText" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
            </StackPanel>
            <Button x:Name="ResetAllButton" Content="Reset all to default" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Click="ResetAll_Click" />
        </Grid>

        <!-- Active-rule banner -->
        <Border x:Name="RuleBanner" Grid.Row="1" Visibility="Collapsed"
                Background="{StaticResource AccentDimBrush}" CornerRadius="8"
                Padding="14,9" Margin="0,0,0,14">
            <TextBlock x:Name="RuleBannerText" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
        </Border>

        <!-- Monitor cards (filled in code-behind) -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="MonitorsHost">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,16,0,0" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="AppRulesButton" Grid.Column="0" Content="App rules…"
                        Style="{StaticResource AccentButton}" Click="AppRules_Click" />

                <TextBlock x:Name="StatusText" Grid.Column="1" HorizontalAlignment="Right"
                           VerticalAlignment="Center" Margin="16,0,16,0"
                           Foreground="{StaticResource MutedBrush}" FontSize="12" />

                <CheckBox x:Name="StartupToggle" Grid.Column="2" Content="Run on Windows startup"
                          VerticalAlignment="Center"
                          Checked="StartupToggle_Changed" Unchecked="StartupToggle_Changed" />
            </Grid>
        </Border>

        <!-- In-app modal overlay for App rules (spans the whole window) -->
        <local:AppRulesPanel x:Name="RulesOverlay" Grid.Row="0" Grid.RowSpan="4"
                             Margin="-24" Visibility="Collapsed" />
    </Grid>
</Window>
