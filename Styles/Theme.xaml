<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================================
         Luminosity — deep-space / aurora theme
         Ported from the design mockup (luminosity.css). The signature is the
         "sliders are the light": each control's track is its own spectrum.
         ========================================================================= -->

    <!-- —— surfaces (near-black, cool) —— -->
    <Color x:Key="BgColor">#05070C</Color>
    <Color x:Key="PanelColor">#0D111B</Color>
    <Color x:Key="CardColor">#11151F</Color>
    <Color x:Key="CardHiColor">#141926</Color>
    <Color x:Key="InsetColor">#0A0D15</Color>
    <Color x:Key="CardBorderColor">#1B2230</Color>
    <Color x:Key="BorderHiColor">#2A3346</Color>
    <Color x:Key="TitlebarColor">#0A0E16</Color>

    <!-- —— ink —— -->
    <Color x:Key="TextColor">#E9EEFB</Color>
    <Color x:Key="TextDimColor">#AAB3C8</Color>
    <Color x:Key="MutedColor">#69728A</Color>

    <!-- —— aurora signature —— -->
    <Color x:Key="AuroraVioletColor">#8D6CFF</Color>
    <Color x:Key="AuroraIndigoColor">#5B7CFF</Color>
    <Color x:Key="AuroraCyanColor">#34E0E6</Color>
    <Color x:Key="AuroraMintColor">#5CF2A6</Color>
    <Color x:Key="AccentColor">#34E0E6</Color>      <!-- single-tone accent = cyan -->
    <Color x:Key="AccentDimColor">#1E6E72</Color>
    <Color x:Key="TrackColor">#0A0D15</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="CardHiBrush" Color="{StaticResource CardHiColor}" />
    <SolidColorBrush x:Key="InsetBrush" Color="{StaticResource InsetColor}" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}" />
    <SolidColorBrush x:Key="BorderHiBrush" Color="{StaticResource BorderHiColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDimColor}" />
    <SolidColorBrush x:Key="TrackBrush" Color="{StaticResource TrackColor}" />

    <!-- Aurora gradient: violet -> indigo -> cyan -> mint -->
    <LinearGradientBrush x:Key="AuroraBrush" StartPoint="0,0" EndPoint="1,0.18">
        <GradientStop Color="#8D6CFF" Offset="0" />
        <GradientStop Color="#5B7CFF" Offset="0.26" />
        <GradientStop Color="#34E0E6" Offset="0.60" />
        <GradientStop Color="#5CF2A6" Offset="1" />
    </LinearGradientBrush>

    <!-- Aurora, softened — for the active-rule banner fill -->
    <LinearGradientBrush x:Key="AuroraSoftBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#258D6CFF" Offset="0" />
        <GradientStop Color="#1F34E0E6" Offset="0.6" />
        <GradientStop Color="#1F5CF2A6" Offset="1" />
    </LinearGradientBrush>

    <!-- ============================================================================
         Per-control spectrum gradients — the track literally shows what it does.
         Keyed "Spectrum{ControlName}"; ColorRow assigns one to each Slider.Tag.
         ========================================================================= -->
    <LinearGradientBrush x:Key="SpectrumSaturation" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#6F7790" Offset="0" />
        <GradientStop Color="#3FBFAE" Offset="0.45" />
        <GradientStop Color="#33E6A0" Offset="0.78" />
        <GradientStop Color="#34E0E6" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SpectrumBrightness" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#05070C" Offset="0" />
        <GradientStop Color="#7E88A0" Offset="0.58" />
        <GradientStop Color="#F3F7FF" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SpectrumContrast" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#697292" Offset="0" />
        <GradientStop Color="#AEB8D0" Offset="0.55" />
        <GradientStop Color="#EEF3FC" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SpectrumGamma" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#1A2030" Offset="0" />
        <GradientStop Color="#6E7790" Offset="0.55" />
        <GradientStop Color="#CDD6E8" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SpectrumHue" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#FF5C5C" Offset="0" />
        <GradientStop Color="#FFC24B" Offset="0.18" />
        <GradientStop Color="#5CF2A6" Offset="0.40" />
        <GradientStop Color="#34E0E6" Offset="0.58" />
        <GradientStop Color="#5B7CFF" Offset="0.76" />
        <GradientStop Color="#B36BFF" Offset="0.90" />
        <GradientStop Color="#FF5C5C" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SpectrumTemperature" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#FFB46B" Offset="0" />
        <GradientStop Color="#FFD9B0" Offset="0.25" />
        <GradientStop Color="#FFFFFF" Offset="0.5" />
        <GradientStop Color="#DCE8FF" Offset="0.75" />
        <GradientStop Color="#9EC0FF" Offset="1" />
    </LinearGradientBrush>

    <!-- Card container: subtle top highlight over the card surface -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <!-- ============================================================================
         The spectrum slider — signature element.
         Slider.Tag carries the per-control gradient (set in Ui/ColorRow).
         Rail = dim full-width spectrum over an inset well; fill = vivid spectrum
         with a luminous glow; thumb = white knob with an aurora ring + glow.
         ========================================================================= -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="Height" Value="22" />
        <Setter Property="IsMoveToPointEnabled" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center" Height="22">
                        <!-- rail base well -->
                        <Border Height="7" CornerRadius="4" VerticalAlignment="Center"
                                Background="{StaticResource InsetBrush}" />
                        <!-- dim full-range spectrum -->
                        <Border Height="7" CornerRadius="4" VerticalAlignment="Center" Opacity="0.32"
                                Background="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="7" CornerRadius="4" VerticalAlignment="Center"
                                                    Background="{Binding Tag, RelativeSource={RelativeSource AncestorType=Slider}}">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#34E0E6" BlurRadius="14"
                                                                      ShadowDepth="0" Opacity="0.65" />
                                                </Border.Effect>
                                            </Border>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Grid Width="20" Height="20" Background="Transparent">
                                                <Ellipse x:Name="thumb" Width="17" Height="17"
                                                         Fill="#F3F7FF"
                                                         Stroke="{StaticResource AccentBrush}" StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#34E0E6" BlurRadius="14"
                                                                          ShadowDepth="0" Opacity="0.8" />
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="thumb" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="1.15" ScaleY="1.15"
                                                                            CenterX="8.5" CenterY="8.5" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- —— Ghost (outline) button —— -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
        <Setter Property="Background" Value="#0DFFFFFF" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderHiBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#14FFFFFF" />
                            <Setter TargetName="b" Property="BorderBrush" Value="#3A455C" />
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- —— Accent (aurora-filled) button —— -->
    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
        <Setter Property="Foreground" Value="#061018" />
        <Setter Property="Background" Value="{StaticResource AuroraBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect Color="#34E0E6" BlurRadius="18" ShadowDepth="0" Opacity="0.45" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Opacity" Value="0.92" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- —— Compact icon button (e.g. ↺ reset) —— -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8"
                            BorderThickness="1" BorderBrush="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#0AFFFFFF" />
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource BorderHiBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.25" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- —— Dark text input —— -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="Background" Value="{StaticResource InsetBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderHiBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="9">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- —— Small "chip" button —— -->
    <Style x:Key="ChipButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
        <Setter Property="Background" Value="#09FFFFFF" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8"
                            BorderThickness="1" BorderBrush="{StaticResource BorderHiBrush}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#14FFFFFF" />
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- —— Pill toggle (Run on startup / Show all) —— -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <ContentPresenter Margin="0,0,10,0" VerticalAlignment="Center" />
                        <Border x:Name="track" Width="40" Height="22" CornerRadius="11"
                                Background="{StaticResource InsetBrush}" BorderThickness="1"
                                BorderBrush="{StaticResource BorderHiBrush}" VerticalAlignment="Center">
                            <Ellipse x:Name="knob" Width="15" Height="15" HorizontalAlignment="Left"
                                     Margin="3,0,0,0" Fill="#79839B" />
                        </Border>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="track" Property="Background" Value="{StaticResource AuroraBrush}" />
                            <Setter TargetName="track" Property="BorderBrush" Value="Transparent" />
                            <Setter TargetName="knob" Property="Fill" Value="#061018" />
                            <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="knob" Property="Margin" Value="0,0,3,0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- —— Badge / pill text containers (used in code-behind) —— -->
    <Style x:Key="BackendPill" TargetType="Border">
        <Setter Property="Background" Value="#1434E0E6" />
        <Setter Property="BorderBrush" Value="#3334E0E6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="9,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CapBadge" TargetType="Border">
        <Setter Property="Background" Value="#08FFFFFF" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderHiBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
